{
  "servers": {
    "context-engine": {
      "command": "${env:USERPROFILE}\\.local\\bin\\cce.exe",
      "args": [
        "serve",
        "--project-dir",
        "${workspaceFolder}"
      ]
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e", "SONARQUBE_TOKEN",
        "-e", "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "${SONARQUBE_URL}"
      }
    }
  }
}
