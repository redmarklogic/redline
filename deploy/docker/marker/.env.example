# Environment variables for the marker service.
# Copy to .env and adjust values for your local setup.
# This file is safe to commit — it contains no secrets.

# Host port the marker service is exposed on (compose only).
# The container always listens on PORT (default 8080) internally.
# Override MARKER_PORT to avoid conflicts if 8000 is already in use on the host.
MARKER_PORT=8000

# Internal container port. Injected automatically by Cloud Run in production.
# Set explicitly only for non-standard local testing (e.g. PORT=9000).
# Default: 8080. Do NOT set this in compose for normal local development —
# the compose port mapping "${MARKER_PORT:-8000}:8080" handles the host binding.
# PORT=8080

# Runtime environment. Controls logging verbosity and debug features.
# Values: development | staging | production
APP_ENV=development
