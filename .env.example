# ---------------------------------------------------------------------------
# RedMark SonarQube -- environment template (redline repo)
# ---------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in the secret tokens.
# Committed config holds NON-SECRET values only; tokens live solely in `.env`.
#
#   cp .env.example .env      # then paste your tokens into .env
#
# Generate the tokens once in the local SonarQube UI (http://localhost:9000):
#   My Account -> Security -> Generate Tokens  (type: "User Token").
# ---------------------------------------------------------------------------

# -- Scanner (Phase 2: scan.ps1 / scan.sh) ----------------------------------
# Non-secret: the SonarQube project key analysed by the scanner.
SONAR_PROJECT_KEY=redline

# Non-secret: URL the sonar-scanner CLI container uses to reach the instance.
# The scanner runs as a Docker container, so it reaches the host-published
# port 9000 via host.docker.internal (Windows/macOS Docker Desktop).
SONAR_HOST_URL=http://host.docker.internal:9000

# SECRET: scanner authentication token. Leave blank here; set it only in .env.
SONAR_TOKEN=

# -- MCP server (Phase 3: official mcp/sonarqube) ---------------------------
# The MCP server is registered in committed .mcp.json. Its non-secret
# SONARQUBE_URL is hard-coded there; the secret SONARQUBE_TOKEN is loaded from
# this .env via the server's `envFile` setting. If your VS Code build lacks
# `envFile` support, replace it with an `${input:sonar_token}` secure prompt in
# mcp.json (VS Code asks for the token on first run and stores it encrypted).
#
# Non-secret: URL the SonarQube MCP server uses to reach the instance.
# The official mcp/sonarqube server also runs as a Docker container, so -- like
# the scanner above -- it must reach the host-published port 9000 via
# host.docker.internal, NOT localhost (localhost would resolve to the MCP
# container itself and fail with "Connection refused" at startup).
SONARQUBE_URL=http://host.docker.internal:9000

# SECRET: MCP user token. Leave blank here; set it only in .env.
# May be the same value as SONAR_TOKEN.
SONARQUBE_TOKEN=

# -- Context7 MCP server (.mcp.json: context7) -------------------------------
# Generate at https://context7.com → Settings → API Keys.
# SECRET: Leave blank here; set it only in .env.
CONTEXT7_API_KEY=

# ---------------------------------------------------------------------------
# ADR-026: Firebase Hosting + Cloudflare DNS (issue #111)
# ---------------------------------------------------------------------------
# These variables are required when running `terraform plan/apply` for the
# Firebase Hosting and Cloudflare DNS resources in deploy/infra/terraform/.
# They are NOT injected into the Cloud Run container — they are Terraform operator
# variables only.
# ---------------------------------------------------------------------------

# SECRET: Cloudflare API token with Zone:DNS:Edit + Zone:Zone:Read on redmarklogic.com only.
# Source: Secret Manager secret "prod-redline-cloudflare-api-token" in project redmarklogic-prod.
# Format: string, e.g. "abc123XYZ..." (Cloudflare token format, no prefix).
# Inject before terraform plan/apply:
#   $env:CLOUDFLARE_API_TOKEN = (gcloud secrets versions access latest --secret=prod-redline-cloudflare-api-token --project=redmarklogic-prod)
CLOUDFLARE_API_TOKEN=

# Non-secret: Cloudflare zone ID for redmarklogic.com.
# Source: curl -s "https://api.cloudflare.com/client/v4/zones?name=redmarklogic.com" -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" | jq .result[0].id
# Format: 32-character hex string, no quotes.
CF_ZONE_ID=

# Non-secret: Firebase Hosting CNAME target for api.redmarklogic.com.
# Source: terraform output firebase_custom_domain_required_dns_updates (after first apply of firebase_hosting.tf).
# Format: hostname, e.g. "redmarklogic-api.web.app" (exact value from Firebase output).
# Verified 2026-06-11: Firebase's subdomain flow requires a single CNAME, not the legacy TXT + A pair.
# Set this in terraform.tfvars (not here) once obtained.
FIREBASE_CNAME_TARGET=
