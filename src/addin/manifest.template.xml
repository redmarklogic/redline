  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="__ADDIN_BASE_URL__/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
