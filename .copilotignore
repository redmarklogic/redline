# All dot-prefixed folders (tooling, caches, runtime state)
.*/

# All underscore-prefixed folders
_*/

# Any folder containing _cache in its name, at any depth
**/*_cache*/

# Re-include critical agent and config folders
!.agents/
!.github/
!.specify/

# Dot-prefixed files not covered by the folder rule
.coverage
.secrets.baseline

# Lockfiles (thousands of lines, zero signal)
uv.lock

# Generated output
output/
